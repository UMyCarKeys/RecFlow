# Copy this file to .env and fill in your values

# Supabase (safe to expose — these are public keys)
VITE_SUPABASE_URL=https://xxxxx.supabase.co
VITE_SUPABASE_ANON_KEY=eyJ...

# Optional: GIF post-its (get a free key at https://developers.giphy.com)
VITE_GIPHY_API_KEY=

